# Atlas of Australia — environment variables
# Copy to .env and fill in as needed. Everything has a sane default for local dev.

# --- Host ports ---
HTTP_PORT=8080

# --- Postgres ---
PG_USER=atlas
PG_PASSWORD=atlas
PG_DB=atlas

# --- Redis ---
# REDIS_URL is set per-service in docker-compose.yml; override here if needed.
# REDIS_URL=redis://redis:6379/0

# --- API ---
# LOG_LEVEL=info
# API_CORS_ORIGINS=*

# --- Frontend build-time ---
# VITE_API_BASE=/api

# --- God's Eye CORS (server.py) ---
# Comma-separated list of allowed origins for the proxy server.
# Default (when unset): http://localhost:8777,http://127.0.0.1:8777
# Add your PythonAnywhere domain to expose the server publicly:
# GODS_EYE_ALLOWED_ORIGINS=https://yourusername.pythonanywhere.com,http://localhost:8777

# --- Google Maps (God's Eye) ---
# Browser key — injected into gods-eye/index.html at serve time by server.py.
# Visible in the served page's DevTools (unavoidable for Maps JS). Protected by
# HTTP referrer restrictions set in Google Cloud Console, NOT by secrecy.
# Restrict to: http://localhost:8777/*, http://127.0.0.1:8777/*, plus any
# production domain you deploy God's Eye to.
# GOOGLE_MAPS_BROWSER_KEY=

# --- MapTiler (God's Eye basemap) ---
# Free tier: 100k tile requests/month. Used for the streets-dark vector basemap
# — denser labels and better POI hierarchy than Carto dark-matter.
# Create at https://www.maptiler.com/cloud/ → Keys. Restrict by Allowed Origins
# to http://localhost:8777 (and any production domain). Visible in page source.
# MAPTILER_KEY=

# --- TomTom (God's Eye traffic) ---
# Free Developer tier: 2,500 tile requests/day. Used for live-traffic flow
# raster tiles overlaid on the basemap (colour-coded road congestion).
# Create at https://developer.tomtom.com/ → Dashboard → apps. Visible in page
# source. Restrict to localhost:8777 + any prod domain.
# TOMTOM_KEY=

# --- TfNSW OpenData (God's Eye traffic incidents) ---
# Required for the Incidents overlay — without it the overlay shows empty.
# Free developer tier, unlimited reads. Signup flow:
#   1. https://opendata.transport.nsw.gov.au/ → create account
#   2. My Account → My Apps → Create new app → tick "Live Traffic — Hazards"
#   3. Copy the generated API key
# Server-side only (never sent to browser); used by /proxy/traffic-incidents.
# NSW_TRAFFIC_API_KEY=

# --- Ingester source credentials (milestone 2+) ---
# OpenSky — free account, higher rate limit
# OPENSKY_USER=
# OPENSKY_PASS=

# TfNSW Open Data API key (transit)
# TFNSW_API_KEY=

# PTV (Vic) developer id + key
# PTV_DEV_ID=
# PTV_API_KEY=

# TransLink (QLD) — GTFS-R is public, no key required as of writing
# TRANSLINK_API_KEY=

# OpenAustralia / APH
# OPENAUSTRALIA_API_KEY=

# BOM polite user-agent (required for radar tile fetches)
# BOM_USER_AGENT="atlas-of-australia/0.1 (contact: you@example.com)"

# Yahoo Finance — unofficial, no key, set a polite UA
# YAHOO_USER_AGENT="atlas-of-australia/0.1"
